#!/usr/bin/env python3
"""Compatibility shim: ``hermes`` is now ``centurion``.

This wrapper delegates to the installed ``centurion`` command.
Users should migrate scripts from ``hermes`` to ``centurion``.
"""
import sys
from centurion_cli.main import main

if __name__ == "__main__":
    # Warn once that this is deprecated
    if "-q" not in sys.argv and "--quiet" not in sys.argv:
        print("⚠  'hermes' is deprecated — use 'centurion' instead.", file=sys.stderr)
    main()
